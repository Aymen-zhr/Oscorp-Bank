APP_NAME=Oscorp
APP_ENV=production
APP_KEY=
APP_DEBUG=false
APP_URL=http://localhost

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=sqlite
DB_DATABASE=/data/database/database.sqlite

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=database

MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

VITE_APP_NAME="${APP_NAME}"
VITE_LOGO_DEV_KEY=

# Balance & Limits
BASE_BALANCE=12500.00

# Tax Configuration
TAX_DEFAULT_INCOME=500000

# Loan Configuration
LOAN_ESTIMATION_MULTIPLIER=0.15
LOAN_PRE_APPROVED_MULTIPLIER=3
LOAN_AMORTIZATION_MONTHS=12
LOAN_MORTGAGE_PRINCIPAL=1200000
LOAN_MORTGAGE_BALANCE=985400
LOAN_MORTGAGE_RATE=3.5
LOAN_MORTGAGE_MONTHLY=8500
LOAN_AUTO_PRINCIPAL=250000
LOAN_AUTO_BALANCE=142000
LOAN_AUTO_RATE=4.2
LOAN_AUTO_MONTHLY=4800
LOAN_PERSONAL_MAX=500000
LOAN_PERSONAL_RATE=5.5
LOAN_BUSINESS_MAX=2000000
LOAN_BUSINESS_RATE=4.8
LOAN_EDUCATION_MAX=300000
LOAN_EDUCATION_RATE=3.2

# Tax Configuration
TAX_DEFAULT_INCOME=500000
TAX_BRACKET_1_THRESHOLD=30000
TAX_BRACKET_2_THRESHOLD=50000
TAX_BRACKET_3_THRESHOLD=60000
TAX_BRACKET_3_CUMULATIVE=2000
TAX_BRACKET_4_THRESHOLD=80000
TAX_BRACKET_4_CUMULATIVE=4000
TAX_BRACKET_5_THRESHOLD=180000
TAX_BRACKET_5_CUMULATIVE=10000
TAX_BRACKET_6_CUMULATIVE=44000

# Currency & Balance
APP_CURRENCY=MAD
BASE_BALANCE=12500.00

# Card Configuration
DEFAULT_CARD_LAST4=9984
DEFAULT_CARD_EXPIRY=12/28
DEFAULT_CARD_LIMIT=50000
DEFAULT_CARD_GRADIENT=linear-gradient(135deg, #1a1a1a 0%, #0a0a0a 100%)
DEFAULT_CARD_TEXTURE=url("https://www.transparenttextures.com/patterns/carbon-fibre.png")

# RIB Configuration
RIB_FULL=181 810 0000000000000000 84
RIB_BANK_CODE=181
RIB_BRANCH_CODE=810
RIB_ACCOUNT_NUMBER=0000000000000000
RIB_KEY=84

# Transaction Limits
MAX_TRANSFER=500000
MAX_DEPOSIT=500000
MAX_WITHDRAWAL=500000
PAGINATION_PER_PAGE=20

# OAuth Configuration
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=${APP_URL}/auth/google/callback

# AI Configuration
GEMINI_API_KEY=
GEMINI_API_URL=https://generativelanguage.googleapis.com/v1beta/models/gemini-2.5-flash:generateContent

# Seeder Configuration
SEEDER_ADMIN_NAME=Admin
SEEDER_ADMIN_EMAIL=admin@oscorp.com
SEEDER_ADMIN_PASSWORD=password
SEEDER_USER_NAME=George
SEEDER_USER_EMAIL=george@oscorp.com
SEEDER_USER_PASSWORD=password
